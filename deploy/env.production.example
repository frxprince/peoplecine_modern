APP_NAME="PeopleCine Modern"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:7000
APP_TIMEZONE=Asia/Bangkok
APP_LOCALE=th
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=th_TH

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

DB_CONNECTION=mariadb
DB_HOST=db
DB_PORT=3306
DB_DATABASE=peoplecine
DB_USERNAME=ohm
DB_PASSWORD=2001Serenity

MARIADB_DATABASE=peoplecine
MARIADB_ROOT_PASSWORD=2001Serenity
MARIADB_USER=ohm
MARIADB_PASSWORD=2001Serenity

SQLITE_SOURCE_DATABASE=/var/www/peoplecine_data/bootstrap/sqlite/peoplecine-modern.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

LEGACY_WBOARD_ROOT=/var/www/peoplecine_data/legacy/wboard
LEGACY_WBOARD_FALLBACK_ROOT=/var/www/legacy_source_wboard
PEOPLECINE_WATERMARK_SITE_NAME=www.peoplecine.com
PEOPLECINE_WATERMARK_FONT_PATH=/usr/share/fonts/truetype/tlwg/Garuda.ttf
PEOPLECINE_WATERMARK_FONT_PATHS=/usr/share/fonts/truetype/tlwg/Garuda.ttf|/usr/share/fonts/truetype/tlwg/Waree.ttf|/usr/share/fonts/truetype/noto/NotoSansThai-Regular.ttf|/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf
PEOPLECINE_WATERMARK_TIMESTAMP_FORMAT=Y-m-d H:i:s
PEOPLECINE_POST_IMAGE_LIMIT=12
PEOPLECINE_POST_IMAGE_MAX_KB=4096
PEOPLECINE_POST_IMAGE_MAX_WIDTH=1920
PEOPLECINE_POST_IMAGE_MAX_HEIGHT=1080
PEOPLECINE_FORUM_SEARCH_COOLDOWN_SECONDS=6
PEOPLECINE_FORUM_SEARCH_BURST_LIMIT=8

VITE_APP_NAME="${APP_NAME}"
